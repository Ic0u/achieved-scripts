  XMLHttpRequest.prototype.send=function(...a){const t0=performance.now();const req=captureBodies?(typeof a[0]==='string'?a[0]:'(body)'):'';this.addEventListener('loadend',()=>{const ms=Math.round(performance.now()-t0);netCount++;netCountEl.textContent=`${netCount} req`;let body=''; if(captureBodies){try{body=this.responseText?.slice(0,50_000)||'';}catch{}}
    pushLog('NET',`${this.status} ${this.statusText||''} <span class="small">${esc(this.__url||'xhr')}</span> <span class="right">${ms}ms</span>`,'net');
    if(captureBodies){previewJSON('xhr bodies', {url:this.__url, request:req, responseSnippet:body.slice(0,500)});}
  });return _send.apply(this,a);};
};
