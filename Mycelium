let pickMode=false, pickHandler=null, pickedEl=null;
function infoFor(el){if(!el)return'—';const path=[];let n=el;while(n&&n.nodeType===1){let s=n.nodeName.toLowerCase();if(n.id){s+='#'+n.id;path.unshift(s);break}else{const sib=[...n.parentNode?.children||[]].filter(x=>x.nodeName===n.nodeName);if(sib.length>1){const idx=[...sib].indexOf(n)+1;s+=`:nth-of-type(${idx})`;}path.unshift(s);n=n.parentElement;} }const sel=path.join('>');const xpath=(function(el){if(el.id)return "//*[@id='"+el.id+"']";const parts=[];for(;el&&el.nodeType===1;el=el.parentNode){let ix=1;for(let sib=el.previousSibling;sib;sib=sib.previousSibling){if(sib.nodeType===1&&sib.nodeName===el.nodeName)ix++}parts.unshift(el.nodeName.toLowerCase()+'['+ix+']')}return '/'+parts.join('/')})();return {selector:sel,xpath,classes:[...el.classList]};}
